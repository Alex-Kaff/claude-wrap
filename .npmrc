# This package is developed inside a pnpm workspace but published as a standalone
# npm package. A plain `npm install` in this dir walks up to the monorepo's pnpm
# store and writes a poisoned, monorepo-relative package-lock.json (paths like
# ../../node_modules/.pnpm/...), which makes a standalone clone silently skip all
# devDependencies (no tsc -> build fails). Disabling lockfile writes prevents that.
# A library's lockfile isn't used by consumers, and npm excludes .npmrc from the
# published tarball by default, so this stays local-only.
package-lock=false
